#!/usr/bin/env bash
set -euo pipefail

if ! git diff --cached --name-only --diff-filter=ACM | grep -qE '\.rs$|Cargo\.(toml|lock)$'; then
    exit 0
fi

echo "[pre-commit] cargo fmt --check"
cargo fmt --all -- --check

echo "[pre-commit] cargo clippy"
cargo clippy --workspace --all-targets --all-features -- -D warnings
